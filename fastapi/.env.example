# Gateway toggle
NL_USE_AI_GATEWAY=1
NL_SEARCH_TARGET_DOMAIN=routes
AI_GATEWAY_PROVIDER_PRIORITY=Gemini,Groq,Cerebras,OpenRouter,Cohere,Mistral
AI_GATEWAY_TIMEOUT_SECONDS=12
AI_GATEWAY_BLACKLIST_TTL_SECONDS=300

# Provider API keys (set the ones you want to enable)
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=

# Optional model overrides
GROQ_MODEL=llama-3.3-70b-versatile
CEREBRAS_MODEL=llama-3.3-70b
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free
GEMINI_MODEL=gemini-2.5-flash
MISTRAL_MODEL=mistral-tiny
COHERE_MODEL=command

# Optional OpenRouter metadata headers
OPENROUTER_REFERER=https://vamo.local
OPENROUTER_APP_NAME=VAMO
